<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".exchangeFrag">

        <!--    Screen Layout-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_color"
            android:orientation="vertical">
                <!--Dashboard Container-->
                <LinearLayout
                    android:id="@+id/dashboardCurrencyLayout"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="5dp"
                    android:gravity="center"
                    android:layout_marginBottom="25dp"
                    >
                        <!--Title Container-->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="25dp"
                            android:layout_marginRight="25dp"
                            android:layout_marginBottom="10dp">


                                <TextView
                                    android:id="@+id/txtpageTitle"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:layout_margin="5dp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Exchange"
                                    style="@style/db_frag_title">

                                </TextView>

                        </LinearLayout>
                        <!-- Exchange Layout-->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center">
                                <!--Exchange container-->
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="200dp"
                                    android:layout_marginLeft="25dp"
                                    android:layout_marginRight="25dp"
                                    android:orientation="horizontal"
                                    android:background="@drawable/rounded_container"
                                    >
                                        <LinearLayout
                                            android:layout_width="60dp"
                                            android:layout_height="match_parent"
                                            android:orientation="vertical">
                                                <ImageButton
                                                    android:id="@+id/btn_swap"
                                                    android:layout_width="match_parent"
                                                    android:layout_height="match_parent"
                                                    android:src="@drawable/ic_exchange"
                                                    android:background="@drawable/btn_border"/>
                                        </LinearLayout>

                                        <LinearLayout
                                            android:layout_width="wrap_content"
                                            android:layout_height="match_parent"
                                            android:orientation="vertical"
                                            android:background="@drawable/divider"
                                            >

                                                <LinearLayout
                                                    android:layout_width="match_parent"
                                                    android:layout_height="wrap_content"
                                                    android:orientation="horizontal"
                                                    android:layout_margin="2dp"
                                                    android:layout_weight="1">
                                                        <LinearLayout
                                                            android:layout_width="match_parent"
                                                            android:layout_height="match_parent"
                                                            android:layout_weight="1"
                                                            android:padding="10dp"
                                                            android:orientation="vertical">
                                                                <TextView
                                                                    android:layout_width="wrap_content"
                                                                    android:layout_height="wrap_content"
                                                                    android:textColor="@color/text_color"
                                                                    android:textSize="15dp"
                                                                    android:text="YOU HAVE">

                                                                </TextView>
                                                                <TextView
                                                                    android:id="@+id/txtCurrentVal"
                                                                    android:layout_width="match_parent"
                                                                    android:layout_height="wrap_content"
                                                                    android:textSize="25sp"
                                                                    android:textColor="@color/text_color"
                                                                    android:textStyle="bold"
                                                                    android:text=""

                                                                    android:gravity="start"
                                                                    android:textAlignment="viewStart"

                                                                    android:singleLine="true"
                                                                    android:ellipsize="none"
                                                                    android:scrollHorizontally="true"
                                                                    >

                                                                </TextView>
                                                                <TextView
                                                                    android:id="@+id/lblConvertionRate"
                                                                    android:layout_width="wrap_content"
                                                                    android:layout_height="wrap_content"
                                                                    android:textColor="@color/text_color"
                                                                    android:textSize="10sp"
                                                                    android:text="">

                                                                </TextView>



                                                        </LinearLayout>
                                                        <LinearLayout
                                                            android:layout_width="match_parent"
                                                            android:layout_height="match_parent"
                                                            android:padding="15dp"
                                                            android:layout_weight="1"
                                                            android:gravity="right">

                                                                <TextView
                                                                    android:id="@+id/lblChangeCurrVal"
                                                                    android:layout_width="wrap_content"
                                                                    android:layout_height="wrap_content"
                                                                    style="@style/db_txtBody"
                                                                    android:layout_margin="15dp"
                                                                    android:text="PHP">

                                                                </TextView>
                                                                <ImageButton
                                                                    android:id="@+id/btnChangeCurrVal"
                                                                    android:layout_gravity="center"
                                                                    android:layout_width="wrap_content"
                                                                    android:layout_height="wrap_content"
                                                                    android:background="#00000000"
                                                                    android:src="@drawable/ic_3_dot_option">
                                                                </ImageButton>


                                                        </LinearLayout>

                                                </LinearLayout>
                                                <com.google.android.material.divider.MaterialDivider
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="1dp"/>
                                                <LinearLayout
                                                    android:layout_width="match_parent"
                                                    android:layout_height="wrap_content"
                                                    android:orientation="horizontal"
                                                    android:layout_margin="2dp"
                                                    android:layout_weight="1">
                                                        <LinearLayout
                                                            android:layout_width="match_parent"
                                                            android:layout_height="match_parent"
                                                            android:layout_weight="1"
                                                            android:padding="10dp"
                                                            android:orientation="vertical">
                                                                <TextView
                                                                    android:layout_width="wrap_content"
                                                                    android:layout_height="wrap_content"
                                                                    android:textColor="@color/text_color"
                                                                    android:textSize="15dp"
                                                                    android:text="YOU HAVE">

                                                                </TextView>
                                                                <TextView
                                                                    android:id="@+id/lblConvertedBal"
                                                                    android:layout_width="match_parent"
                                                                    android:layout_height="wrap_content"
                                                                    android:textSize="25sp"
                                                                    android:textStyle="bold"
                                                                    android:textColor="@color/text_color"
                                                                    android:text="">

                                                                </TextView>



                                                        </LinearLayout>
                                                        <LinearLayout
                                                            android:layout_width="match_parent"
                                                            android:layout_height="match_parent"
                                                            android:padding="15dp"
                                                            android:layout_weight="1"
                                                            android:gravity="right">

                                                                <TextView
                                                                    android:id="@+id/lblChangeConvVal"
                                                                    android:layout_width="wrap_content"
                                                                    android:layout_height="wrap_content"
                                                                    style="@style/db_txtBody"
                                                                    android:layout_margin="15dp"
                                                                    android:text="USD">

                                                                </TextView>
                                                                <ImageButton
                                                                    android:id="@+id/btnChangeConvVal"
                                                                    android:layout_gravity="center"
                                                                    android:layout_width="wrap_content"
                                                                    android:layout_height="wrap_content"
                                                                    android:background="#00000000"
                                                                    android:src="@drawable/ic_3_dot_option">
                                                                </ImageButton>


                                                        </LinearLayout>

                                                </LinearLayout>
                                        </LinearLayout>




                                </LinearLayout>

                        </LinearLayout>
                </LinearLayout>
                <!-- Button Exchange Container-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="5dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="25dp"
                            android:layout_marginRight="25dp"
                            android:orientation="horizontal"
                            android:gravity="right">

                                <ImageButton
                                    android:id="@+id/btnExchange"
                                    android:layout_width="175dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/btn_rounded"
                                    android:src="@drawable/ic_exchange_light">

                                </ImageButton>
                        </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="25dp"
                    android:paddingTop="15dp"
                    android:layout_weight="1">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginLeft="25dp"
                            android:layout_marginRight="25dp"
                            android:background="@drawable/scroll_container">
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                        <Button
                                            android:id="@+id/btn1"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="1" />

                                        <Button
                                            android:id="@+id/btn2"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="2" />

                                        <Button
                                            android:id="@+id/btn3"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="3" />
                                </LinearLayout>


                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                        <Button
                                            android:id="@+id/btn4"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="4" />

                                        <Button
                                            android:id="@+id/btn5"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="5" />

                                        <Button
                                            android:id="@+id/btn6"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="6" />
                                </LinearLayout>


                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                        <Button
                                            android:id="@+id/btn7"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="7" />

                                        <Button
                                            android:id="@+id/btn8"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="8" />

                                        <Button
                                            android:id="@+id/btn9"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="9" />
                                </LinearLayout>


                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                        <Button
                                            android:id="@+id/btn0"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="0" />

                                        <Button
                                            android:id="@+id/btnDec"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="." />

                                        <Button
                                            android:id="@+id/btnDelete"
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            style="@style/numpad_btn"
                                            android:text="⌫" />
                                </LinearLayout>

                        </LinearLayout>

                </LinearLayout>
        </LinearLayout>




</FrameLayout>