<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="bottom"
    android:layout_gravity="start"
    android:background="@drawable/boot1_bg_gradient"
    android:id="@+id/main"
    tools:context=".Boot1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:padding="5dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="60dp"
        android:padding="5dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="5"
            android:orientation="vertical"
            android:paddingLeft="10dp">

            <TextView
                style="@style/txtBody_type1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name_apk">


            </TextView>

            <TextView
                style="@style/txtTitle_type1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tagline_1">


            </TextView>

            <TextView
                style="@style/txtBody_type1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/info1">


            </TextView>


        </LinearLayout>

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_margin="15dp"
            android:background="#00000000"
            android:src="@drawable/nxt_arrow" />
    </LinearLayout>
    </LinearLayout>

</LinearLayout>