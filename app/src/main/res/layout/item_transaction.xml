<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/navbar_container"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_margin="15dp"
        android:layout_marginLeft="20dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_weight="1">

            <TextView
                android:id="@+id/lblExch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/lbl_transact"
                android:text="USD"/>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow"/>

            <TextView
                android:id="@+id/lblCurr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/lbl_transact"
                android:text="PHP"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <TextView
                android:id="@+id/lblExchVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/lbl_transact2"
                android:text="10"/>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow2"/>

            <TextView
                android:id="@+id/lblCurrVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/lbl_transact2"
                android:text="5600"/>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="right"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginRight="20dp">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_recent"/>

            <TextView
                android:id="@+id/lblTrs_Date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                style="@style/lbl_transact"
                android:text="Mar 7"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                style="@style/lbl_transact"
                android:text="•"/>

            <TextView
                android:id="@+id/lblTrs_Time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                style="@style/lbl_transact"
                android:text="10:32"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>