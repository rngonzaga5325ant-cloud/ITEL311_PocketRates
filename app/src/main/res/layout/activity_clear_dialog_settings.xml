<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:background="@drawable/rounded_dialog_bg"
        android:orientation="vertical"
        android:padding="10dp"
        tools:context=".clearDialog_settings">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="10dp"
            >

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="30dp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:text="Clear Transaction"
                android:layout_margin="5dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="20dp"
                style="@style/txtBody_type2"
                android:text="Are you sure you want to clear\nyour transaction history?"
                android:layout_margin="5dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textSize="15dp"
                android:textColor="#717171"
                android:text="This will permanently delete all your recorded\ncurrency conversions. This action\ncannot be undone."
                android:layout_margin="5dp"/>

        </LinearLayout>

        <!-- Loading View (Hidden by default) -->
        <LinearLayout
            android:id="@+id/loadingLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_margin="20dp">

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/btn_color"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Clearing history..."
                android:textColor="@color/text_color2"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/buttonLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="10dp">

            <Button
                android:id="@+id/btnDialogClearDB"
                android:layout_width="250dp"
                android:layout_height="55dp"
                style="@style/btnFilled"
                android:text="Clear History"
                >

            </Button>
            <Button
                android:id="@+id/btnCancel"
                android:layout_width="250dp"
                android:layout_height="45dp"
                style="@style/btnHollow"
                android:text="Cancel"
                >

            </Button>


        </LinearLayout>

    </LinearLayout>
</FrameLayout>