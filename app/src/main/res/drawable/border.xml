<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Background color of the view -->
    <solid android:color="#00000000" />

    <!-- Border thickness and color -->
