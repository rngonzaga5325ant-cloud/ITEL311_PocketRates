<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow shape (blur effect) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />  <!-- semi‑transparent black -->
            <corners  android:bottomRightRadius="12px" android:topRightRadius="12px" />
        </shape>
    </item>

    <!-- Actual shape (slightly offset) -->
    <item android:left="2dp" android:bottom="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:bottomLeftRadius="0px" android:topLeftRadius="0px" android:topRightRadius="12px" android:bottomRightRadius="12px" />
        </shape>
    </item>
</layer-list>