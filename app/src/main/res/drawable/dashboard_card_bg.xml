<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A5C6BF2" />
            <corners android:radius="30dp" />
        </shape>
    </item>

    <!-- Gradient Background -->
    <item android:bottom="4dp" android:right="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#5C6BF2"
                android:endColor="#818CF8"
                android:angle="45" />
            <corners android:radius="30dp" />
        </shape>
    </item>
</layer-list>